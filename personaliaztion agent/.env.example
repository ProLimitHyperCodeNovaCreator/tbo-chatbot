# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/personalization_db

# Application Settings
APP_NAME=Personalization Agent
DEBUG=False
LOG_LEVEL=INFO

# ML Model Settings
MODEL_PATH=model.joblib
MIN_TRAINING_SAMPLES=100
MODEL_FALLBACK_SCORE=0.0

# Scoring Weights
RULE_WEIGHT=1.0
ML_WEIGHT=1.0

# Cache Settings
CACHE_TTL=300

# Performance Settings
BATCH_SIZE=100
MAX_OPTIONS_PER_REQUEST=100

# Feature Flags
ENABLE_ML_SCORING=True
ENABLE_CACHING=True
ENABLE_METRICS=True
