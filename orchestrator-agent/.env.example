# Orchestrator Agent Configuration
ENVIRONMENT=development
DEBUG=true

# Model Configuration
OLLAMA_HOST=http://localhost:11434
PHI4_MODEL=phi4
LLAMA_MODEL=llama2

# Complexity Threshold (0-1)
COMPLEXITY_THRESHOLD=0.6

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/orchestrator

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Agent Endpoints
PERSONALIZATION_AGENT_URL=http://localhost:8001
HOTEL_SEARCH_AGENT_URL=http://localhost:8002
AMADEUS_AGENT_URL=http://localhost:8003

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Timeout Configuration
QUERY_TIMEOUT=30
MODEL_TIMEOUT=60
