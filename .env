# TBO ChatBot Platform - Environment Configuration

# Database
DB_USER=user
DB_PASSWORD=password
DATABASE_URL=postgresql://user:password@postgres:5432/orchestrator

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Qdrant Vector DB
QDRANT_API_KEY=
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Ollama LLM
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODELS=phi4:latest,llama2:latest

# Hotel Search Service
HOTEL_SEARCH_URL=http://hotel-search:5000
MAX_RESULTS=10

# Orchestrator Agent
ENVIRONMENT=production
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Agent Endpoints (if running separately)
PERSONALIZATION_AGENT_URL=http://localhost:8001
HOTEL_SEARCH_AGENT_URL=http://localhost:8002
AMADEUS_AGENT_URL=http://localhost:8003

# Complexity Detection
COMPLEXITY_THRESHOLD=0.6

# Model Configuration
PHI4_MODEL=phi4:latest
LLAMA_MODEL=llama2:latest
